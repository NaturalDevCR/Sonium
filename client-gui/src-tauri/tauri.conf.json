{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sonium",
  "version": "0.1.54",
  "identifier": "com.sonium.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Sonium",
        "width": 800,
        "height": 600,
        "visible": true,
        "label": "main",
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "windowEffects": {
          "effects": [
            "windowBackground"
          ],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
