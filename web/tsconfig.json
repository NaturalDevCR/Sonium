{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "strict":           true,
    "jsx":              "preserve",
    "lib":              ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl":          ".",
    "paths":            { "@/*": ["src/*"] },
    "types":            ["vite/client"],
    "skipLibCheck":     true
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
